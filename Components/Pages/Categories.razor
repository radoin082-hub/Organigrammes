@page "/categories"
@using Compta.Ledger.Core.orgTestapp.Services
@using Compta.Ledger.Core.orgTestapp.Entities
@using Compta.Ledger.Core.orgTestapp.App
@attribute [StreamRendering]
@rendermode InteractiveServer

<PageTitle>Category</PageTitle>

<div class="container mt-4">
    

    <div class="row">
        <div class="col-md-8">
            <CategoryTree />
        </div>
        
        <div class="col-md-4">

        </div>
    </div>
</div>

<style>
    .stat-item {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #dee2e6;
    }

    .stat-item:last-child {
        border-bottom: none;
    }

    .stat-label {
        font-weight: 600;
        color: #666;
    }

    .stat-value {
        font-weight: bold;
        color: #007bff;
        font-size: 1.2em;
    }

    .tips-list {
        margin: 0;
        padding-left: 20px;
    }

    .tips-list li {
        margin-bottom: 8px;
        line-height: 1.5;
    }
</style>


