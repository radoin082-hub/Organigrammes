@using Compta.Ledger.Core.orgTestapp.App
@using Compta.Ledger.Core.orgTestapp.Services
@using Compta.Ledger.Core.orgTestapp.Entities
@rendermode InteractiveServer

<div class="category-tree">
    
    <div class="mb-3">
        <button class="btn btn-success btn-sm" @onclick="OpenAddRootModal"> Add Root</button>
    </div>

    @if (RootNodes != null && RootNodes.Any())
    {
        <div class="tree-container">
            @foreach (var node in RootNodes)
            {
                <TreeNode Node="node" Service="OrgService" OnNodeDeleted="NodeDeleted" OnNodeMoved="NodeMoved" />
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>No categories yet!</strong> Click "Add Root Category" to create your first category.
        </div>
    }
</div>

@* Modal for Add Root Category *@
@if (ShowRootModal)
{
    <div class="modal-backdrop" @onclick="CloseAddRootModal"></div>
    <div class="modal-dialog-container">
        <div class="modal-box">
            <div class="modal-header">
                <h5>Create</h5>
                <button class="close-btn" @onclick="CloseAddRootModal">✕</button>
            </div>
            <div class="modal-body">
                <input type="text" class="modal-input" @bind="NewRootName" 
                    placeholder="Enter category name" @onkeydown="HandleRootKeyDown" autofocus />
            </div>
            <div class="modal-footer">
                <button class="btn-modal btn-cancel" @onclick="CloseAddRootModal">Cancel</button>
                <button class="btn-modal btn-save" @onclick="AddRootCategory">Add Category</button>
            </div>
        </div>
    </div>
}

<style>
    .category-tree { padding: 16px; background: #f8f9fa; border-radius: 8px; }
    .category-tree h3 { margin-bottom: 16px; color: #333; }
    .tree-container { background: white; border-radius: 4px; padding: 8px; }
    
    /* Modal Styles */
    .modal-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        z-index: 1000;
    }
    
    .modal-dialog-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1001;
        pointer-events: none;
    }
    
    .modal-box {
        background: white;
        border-radius: 8px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
        width: 400px;
        max-width: 90%;
        pointer-events: auto;
        animation: modalSlideIn 0.2s ease;
    }
    
    @@keyframes modalSlideIn {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 4px 10px;
        border-bottom: 1px solid #e0e0e0;
    }
    
    .modal-header h5 {
        margin: 0;
        font-size: 16px;
        font-weight: 600;
    }
    
    .close-btn {
        background: none;
        border: none;
        font-size: 18px;
        cursor: pointer;
        color: #666;
        padding: 0;
    }
    
    .close-btn:hover {
        color: #333;
    }
    
    .modal-body {
        padding: 20px;
    }
    
    .modal-body label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: #555;
        margin-bottom: 6px;
    }
    
    .modal-input {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 14px;
        box-sizing: border-box;
    }
    
    .modal-input:focus {
        outline: none;
        border-color: #0078d4;
        box-shadow: 0 0 0 2px rgba(0, 120, 212, 0.1);
    }
    
    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        padding: 5px 10px;
        border-top: 1px solid #e0e0e0;
        background: #f8f9fa;
        border-radius: 0 0 8px 8px;
    }
    
    .btn-modal {
        padding: 4px 12px;
        border: none;
        border-radius: 4px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
    }
    
    .btn-cancel {
        background: #e0e0e0;
        color: #333;
    }
    
    .btn-cancel:hover {
        background: #d0d0d0;
    }
    
    .btn-save {
        background: #28a745;
        color: white;
    }
    
    .btn-save:hover {
        background: #218838;
    }
</style>

@code {
    [Inject] public IOrgService OrgService { get; set; } = null!;

    private List<Node> RootNodes = new();
    private bool ShowRootModal = false;
    private string NewRootName = string.Empty;

    protected override void OnInitialized()
    {
        LoadRootNodes();
    }

    private void LoadRootNodes()
    {
        var allNodes = OrgService.GetAllNodes();
        // Root nodes are at Level 1 (e.g., /1/, /2/, /3/)
        RootNodes = allNodes.Where(n => n.Level == 1).ToList();
    }

    private void OpenAddRootModal()
    {
        NewRootName = string.Empty;
        ShowRootModal = true;
    }

    private void CloseAddRootModal()
    {
        ShowRootModal = false;
        NewRootName = string.Empty;
    }

    private async Task HandleRootKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddRootCategory();
        else if (e.Key == "Escape") CloseAddRootModal();
    }

    private void AddRootCategory()
    {
        if (!string.IsNullOrWhiteSpace(NewRootName))
        {
            var rootNode = new Node { Name = NewRootName };
            OrgService.CreateOrg(rootNode);
            NewRootName = string.Empty;
            ShowRootModal = false;
            LoadRootNodes();
        }
    }

    private void RefreshTree() => LoadRootNodes();
    private void NodeDeleted() => LoadRootNodes();
    private void NodeMoved() => LoadRootNodes();
}
